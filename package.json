{
  "name": "cidfae-gestion-tecnica",
  "version": "1.0.0",
  "description": "Sistema de gestión técnica de proyectos para CIDFAE — Fuerza Aérea Ecuatoriana",
  "author": "CIDFAE <cidfae@fae.mil.ec>",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "electron:dev": "electron .",
    "electron:build": "node scripts/pre-build.js && next build && node scripts/prepare-standalone.js && electron-builder --win --x64",
    "make-ico": "node scripts/make-ico.js",
    "dist": "node scripts/make-ico.js && node scripts/pre-build.js && next build && node scripts/prepare-standalone.js && electron-builder --win --x64"
  },
  "build": {
    "appId": "ec.gov.fae.cidfae",
    "productName": "CIDFAE Gestión Técnica",
    "copyright": "Copyright © 2025 CIDFAE — Fuerza Aérea Ecuatoriana",
    "directories": {
      "output": "dist-exe"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/icon.ico",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "CIDFAE Gestión"
    },
    "files": [
      "electron/**/*",
      ".next/standalone/**/*",
      ".next/standalone/.next/**/*",
      "package.json"
    ],
    "extraResources": [],
    "compression": "normal",
    "asar": false
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.98.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.0",
    "lucide-react": "^0.577.0",
    "next": "16.1.6",
    "next-pwa": "^5.6.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "recharts": "^3.7.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "electron": "^40.7.0",
    "electron-builder": "^26.8.1",
    "electron-is-dev": "^3.0.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "png-to-ico": "^3.0.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
